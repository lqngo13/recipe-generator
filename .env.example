# Copy this file to .env and fill in your values
# The .env file is gitignored so your secrets stay private

# Supabase (or any PostgreSQL) connection string
# Find this in your Supabase project: Settings → Database → Connection string → URI
DATABASE_URL=your_supabase_connection_string_here

# Get your Gemini API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# A random secret string used to sign session cookies
# You can use anything — e.g. a long random phrase
SESSION_SECRET=change-this-to-something-random

# Port the server runs on (Render sets this automatically — leave blank in Render's dashboard)
PORT=3000
